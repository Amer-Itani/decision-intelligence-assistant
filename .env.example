# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000

# LLM Provider
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Retrieval / Storage
CHROMA_PERSIST_DIRECTORY=/app/artifacts/chroma
RETRIEVAL_INDEX_PATH=/app/artifacts/retrieval_index.joblib
TOP_K_RESULTS=5

# Local project paths
MODEL_ARTIFACT_PATH=/app/artifacts/priority_model.joblib
VECTORIZER_ARTIFACT_PATH=/app/artifacts/vectorizer.joblib
LABEL_ENCODER_ARTIFACT_PATH=/app/artifacts/label_encoder.joblib
MODEL_METADATA_ARTIFACT_PATH=/app/artifacts/model_metadata.json
LOG_PATH=/app/logs/requests.jsonl
LLM_INPUT_COST_PER_1M_TOKENS=0.05
LLM_OUTPUT_COST_PER_1M_TOKENS=0.08

# Data
DATASET_PATH=/app/data/sample/customer_support_sample.csv
